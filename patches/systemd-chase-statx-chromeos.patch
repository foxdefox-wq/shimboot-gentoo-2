+static int chase_xstatx(int fd, unsigned mask, struct statx *ret) {
+        int r;
+
+        r = xstatx_full(fd,
+                        /* path= */ NULL,
+                        /* statx_flags= */ 0,
+                        XSTATX_MNT_ID_BEST,
+                        mask,
+                        /* optional_mask= */ 0,
+                        /* mandatory_attributes= */ 0,
+                        ret);
+        if (r >= 0)
+                return r;
+
+        /* ChromeOS shim kernels / pivot_root mount trees can make statx() mount
+         * id probing fail (observed as EPROTO: "Protocol driver not attached")
+         * even for ordinary directories such as /etc/udev and /usr/lib/tmpfiles.d.
+         * udevadm and systemd-tmpfiles do not need mount IDs for common path
+         * canonicalization, so fall back to a plain statx() result. The few code
+         * paths that truly need mount comparison will later get -ENODATA from
+         * statx_mount_same() if no mount ID is available. */
+        if (!IN_SET(r, -EPROTO, -EUNATCH, -EINVAL, -ENOSYS, -EOPNOTSUPP))
+                return r;
+
+        return xstatx_full(fd,
+                        /* path= */ NULL,
+                        /* statx_flags= */ 0,
+                        /* xstatx_flags= */ 0,
+                        mask,
+                        /* optional_mask= */ 0,
+                        /* mandatory_attributes= */ 0,
+                        ret);
+}
